{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "dependsOn": ["^topo"],
      "cache": false,
      "outputs": []
    },
    "format:check": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^topo"],
      "cache": false
    },
    "check-imports": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "ui-add": {
      "cache": false,
      "interactive": true
    }
  }
}
