{
  "name": "@packages/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev",
    "setup": "convex dev --once",
    "test": "if [ -d convex/_generated ]; then vitest run; else echo 'Skipping tests: run bunx convex dev to generate types first'; fi",
    "test:watch": "vitest",
    "typecheck": "if [ -d convex/_generated ]; then tsc --noEmit -p convex/tsconfig.json; else echo 'Skipping typecheck: run bunx convex dev to generate types first'; fi",
    "lint": "eslint convex/ --ignore-pattern '_generated/'",
    "format": "prettier --check \"convex/**/*.{ts,tsx}\" --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "convex": "^1.34.0"
  },
  "devDependencies": {
    "@packages/eslint-config": "workspace:*",
    "@packages/prettier-config": "workspace:*",
    "@packages/typescript-config": "workspace:*",
    "@edge-runtime/vm": "^3.2.0",
    "convex-test": "^0.0.43",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "vitest": "^1.6.0"
  }
}
